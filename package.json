{
  "name": "taskforkstack",
  "version": "0.1.0-dev0",
  "description": "TaskForkStack desktop app",
  "author": "Gary Frattarola <garycoding@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garycoding/TaskForkStack.git"
  },
  "homepage": "https://github.com/garycoding/TaskForkStack#readme",
  "bugs": {
    "url": "https://github.com/garycoding/TaskForkStack/issues"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "legal:prepare": "node scripts/prepare-legal.mjs",
    "legal:notices": "generate-license-file --input ./package.json --output ./legal/THIRD-PARTY-NOTICES.txt --overwrite --eol lf --ci",
    "legal:list": "license-checker-rseidelsohn --production --json --out ./legal/oss-licenses.json && node scripts/clean-oss-licenses.mjs",
    "legal": "npm run legal:prepare && npm run legal:notices && npm run legal:list",
    "build:dist": "npm run legal && electron-vite build && electron-builder"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^34.3.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.5.0",
    "generate-license-file": "^4.2.1",
    "globals": "^17.6.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "overrides": {
    "yauzl": "^3.3.1"
  }
}
