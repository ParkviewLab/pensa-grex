//
// The HomeLab sample forest in the real forest.json5 schema (see
// docs/model_ideas.md) — the same 3-tree, 15-task forest the design mock and
// M1's now-retired render-only fixture drew, in the real data shape. Loaded
// in-renderer via a Vite raw-text import and parsed with the json5 package —
// the same parse path the M4 IPC bridge will use for a real forest file on
// disk. Drives the actual on-screen forest as of M3 (model → measure →
// layout → render).
{
  schema: 1,
  domain: "HomeLab",
  trees: [
    { id: "t_media", name: "Media server", rootTaskId: "k_nas" },
    { id: "t_net", name: "Home network", rootTaskId: "k_rack" },
